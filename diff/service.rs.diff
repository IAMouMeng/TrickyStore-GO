+const KEYBOX_SOCKET: &str = "/dev/socket/keybox";
+
+fn klog(msg: &str) {
+    log::info!("keybox_service: {}", msg);
+}
+/// 请求格式: [total_len: u32 LE][type: u8][uid_len: u32 LE][uid: u32 LE][alias_len: u32 LE][alias: bytes][data_len: u32 LE][data: bytes]
+/// 响应格式: [total_len: u32 LE][status: u8][data_len: u32 LE][data: bytes]
+pub(crate) fn request_from_socket(req_type: u8, uid: u32, alias: &str, orig_data: &[u8]) -> anyhow::Result<Vec<u8>> {
+    klog(&format!("connecting socket, type={}, uid={}, alias={}, orig_data_len={}", req_type, uid, alias, orig_data.len()));
+    let mut stream = UnixStream::connect(KEYBOX_SOCKET)
+        .map_err(|e| {
+            klog(&format!("connect failed: {}", e));
+            e
+        })
+        .context("connect to keybox socket")?;
+    klog("connected");
+
+    let alias_bytes = alias.as_bytes();
+    // total_len = type(1) + uid_len(4) + uid(4) + alias_len(4) + alias(n) + data_len(4) + data(n)
+    let body_len = 1 + 4 + 4 + 4 + alias_bytes.len() + 4 + orig_data.len();
+    let mut req = Vec::with_capacity(4 + body_len);
+    req.extend_from_slice(&(body_len as u32).to_le_bytes());
+    req.push(req_type);
+    req.extend_from_slice(&4u32.to_le_bytes());
+    req.extend_from_slice(&uid.to_le_bytes());
+    req.extend_from_slice(&(alias_bytes.len() as u32).to_le_bytes());
+    req.extend_from_slice(alias_bytes);
+    req.extend_from_slice(&(orig_data.len() as u32).to_le_bytes());
+    req.extend_from_slice(orig_data);
+
+    stream.write_all(&req)
+        .map_err(|e| {
+            klog(&format!("write failed: {}", e));
+            e
+        })
+        .context("write to keybox socket")?;
+    klog("request sent");
+
+    let mut len_buf = [0u8; 4];
+    stream.read_exact(&mut len_buf)
+        .map_err(|e| {
+            klog(&format!("read response length failed: {}", e));
+            e
+        })
+        .context("read response length")?;
+    let total_len = u32::from_le_bytes(len_buf) as usize;
+    klog(&format!("response total_len={}", total_len));
+
+    let mut payload = vec![0u8; total_len];
+    stream.read_exact(&mut payload)
+        .map_err(|e| {
+            klog(&format!("read response payload failed: {}", e));
+            e
+        })
+        .context("read response payload")?;
+    let status = payload.first().unwrap_or(&0);
+    klog(&format!("response status={}", status));
+    if *status != 1 {
+        klog("request failed, status != 1");
+        anyhow::bail!("keybox socket returned failure (status={})", status);
+    }
+    let data_len = u32::from_le_bytes(
+        payload[1..5].try_into().context("parse data_len")?
+    ) as usize;
+    klog(&format!("data_len={}, returning data", data_len));
+    Ok(payload[5..5 + data_len].to_vec())
+}
